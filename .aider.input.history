+[build-system]
+requires = ["setuptools>=64", "wheel>=0.38"]
+build-backend = "setuptools.build_meta"
+
+[project]
+name = "phonebook"
+requires-python = ">=3.11"
+dependencies = [
+    "fastapi>=0.111,<1.0",
+    "uvicorn>=0.29,<1.0",
+    "sqlalchemy>=2.0,<3.0",
