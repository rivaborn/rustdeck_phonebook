# 2026-04-22 05:13:26.034395
+// src/phonebook/static/app.js
+
+/**
+ * Copies the provided text to the clipboard and shows a brief "Copied!" tooltip.
+ * @param {string} text - The text to copy to the clipboard.
+ */
+function copyToClipboard(text) {
+  // Write the text to the clipboard
+  navigator.clipboard.writeText(text).then(() => {
+    // Create a tooltip element
+    const tooltip = document.createElement('div');
+    tooltip.textContent = 'Copied!';
+    tooltip.style.position = 'fixed';
+    tooltip.style.bottom = '10px';
+    tooltip.style.right = '10px';
+    tooltip.style.backgroundColor = 'black';
+    tooltip.style.color = 'white';
+    tooltip.style.padding = '5px 10px';
+    tooltip.style.borderRadius = '4px';
+    tooltip.style.zIndex = '1000';
+    tooltip.style.opacity = '1';
+    tooltip.style.transition = 'opacity 0.5s';
+
+    // Add tooltip to body
+    document.body.appendChild(tooltip);
+
+    // Fade out and remove tooltip after 1 second
+    setTimeout(() => {
+      tooltip.style.opacity = '0';
+      setTimeout(() => {
+        document.body.removeChild(tooltip);
+      }, 500);
+    }, 1000);
+  });
+}
+
+// confirmDelete function is not needed as HTMX handles hx-confirm natively
+// This function may be omitted from the file as per the requirements.
+
+---
+
