# 2026-04-22 04:51:09.698124
+[build-system]
+requires = ["setuptools>=64", "wheel>=0.38"]
+build-backend = "setuptools.build_meta"
+
+[project]
+name = "phonebook"
+requires-python = ">=3.11"
+dependencies = [
+    "fastapi>=0.111,<1.0",
+    "uvicorn>=0.29,<1.0",
